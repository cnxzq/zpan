{
  "name": "@zqzyz/zpan",
  "version": "1.0.2",
  "type": "module",
  "description": "带认证的静态文件网盘，支持文件上传",
  "main": "dist/index.js",
  "bin": {
    "zpan": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli/index.ts start",
    "build": "tsup",
    "start": "node dist/cli/index.js start",
    "test": "vitest",
    "test:run": "vitest run",
    "test:cov": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "cookie-session": "^2.1.0",
    "express": "^4.18.2",
    "multer": "^2.1.1",
    "serve-index": "^1.9.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/cookie-session": "^2.0.49",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.0",
    "@types/serve-index": "^1.9.4",
    "@types/sharp": "^0.32.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3",
    "tsup": "^8.0.1",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2",
    "vitest": "^1.0.1"
  },
  "keywords": [
    "static-server",
    "file-sharing",
    "pan",
    "upload",
    "basic-auth",
    "网盘",
    "file-server"
  ],
  "author": "zhuqiang626@gmail.com",
  "license": "MIT",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "public/**/*"
  ]
}
